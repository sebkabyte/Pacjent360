{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pacjent360.com.pl/schema/patient360.schema.json",
  "title": "Pacjent360™ Data Contract v0.1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "contractVersion",
    "exportedAt",
    "intendedUse",
    "patient",
    "sources",
    "claims",
    "timelineEvents",
    "timelineEpisodes",
    "timelineRelations",
    "consentScopes",
    "audit",
    "sourceQuality",
    "domainData"
  ],
  "properties": {
    "schemaVersion": {
      "const": 7
    },
    "contractVersion": {
      "const": "0.1"
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time"
    },
    "intendedUse": {
      "type": "string",
      "minLength": 1
    },
    "patient": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "timelineEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timelineEvent"
      }
    },
    "timelineEpisodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timelineEpisode"
      }
    },
    "timelineRelations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timelineRelation"
      }
    },
    "consentScopes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/consentScope"
      }
    },
    "audit": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditEntry"
      }
    },
    "sourceQuality": {
      "$ref": "#/$defs/sourceQuality"
    },
    "domainData": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "string",
      "minLength": 1
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "claimType": {
      "enum": [
        "Known",
        "Unknown",
        "Uncertain",
        "To verify",
        "flag:red",
        "flag:amber",
        "flag:green",
        "flag:blue",
        "decisionContext",
        "ditlQuestion",
        "timelineEvent",
        "report"
      ]
    },
    "claimStatus": {
      "enum": [
        "",
        "Known",
        "Unknown",
        "Uncertain",
        "To verify",
        "DITL: do oceny lekarza",
        "do wyjaśnienia",
        "wyjaśnione",
        "odrzucone",
        "dalsza kontrola",
        "potwierdzone",
        "do potwierdzenia",
        "rozbieżność",
        "orientacyjne",
        "planowane"
      ]
    },
    "timelineTrack": {
      "enum": [
        "objawy",
        "badania",
        "leki",
        "kontekst medyczny",
        "hospitalizacje",
        "konsultacje",
        "funkcjonowanie",
        "decyzje medyczne",
        "obserwacje z wywiadu"
      ]
    },
    "timelineStatus": {
      "enum": [
        "potwierdzone",
        "do potwierdzenia",
        "rozbieżność",
        "planowane",
        "orientacyjne"
      ]
    },
    "relationType": {
      "enum": [
        "powiązane czasowo",
        "powiązane źródłem"
      ]
    },
    "consentStatus": {
      "enum": [
        "aktywny",
        "cofnięty",
        "wygasły"
      ]
    },
    "auditActionType": {
      "enum": [
        "local_demo_audit",
        "ditl_status_change",
        "consent_change",
        "export",
        "import",
        "validation"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ref",
        "type",
        "title"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/sourceRef"
        },
        "type": {
          "enum": [
            "document",
            "interview",
            "transcript",
            "observation",
            "medication",
            "flag",
            "decisionContext",
            "report",
            "consent"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "patientId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "recordId": {
          "type": "string"
        },
        "evidenceClass": {
          "enum": [
            "official_document",
            "patient_reported",
            "caregiver_reported",
            "system_generated"
          ]
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "patientId",
        "claimType",
        "text",
        "sourceRefs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "patientId": {
          "type": "string"
        },
        "claimType": {
          "$ref": "#/$defs/claimType"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/claimStatus"
        },
        "sourceRefs": {
          "$ref": "#/$defs/sourceRefs"
        },
        "linkedRef": {
          "type": "string"
        }
      }
    },
    "timelineEvent": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "patientId",
        "date",
        "track",
        "title",
        "status",
        "sourceRefs",
        "claimRefs",
        "schemaStatus"
      ],
      "properties": {
        "track": {
          "$ref": "#/$defs/timelineTrack"
        },
        "status": {
          "$ref": "#/$defs/timelineStatus"
        },
        "sourceRefs": {
          "$ref": "#/$defs/sourceRefs"
        },
        "claimRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schemaStatus": {
          "enum": [
            "projected_from_sources",
            "planned_not_fact"
          ]
        }
      }
    },
    "timelineEpisode": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "patientId",
        "title",
        "startDate",
        "endDate",
        "status",
        "sourceRefs",
        "eventRefs"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/timelineStatus"
        },
        "sourceRefs": {
          "$ref": "#/$defs/sourceRefs"
        },
        "eventRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "timelineRelation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "patientId",
        "fromEventId",
        "toEventId",
        "relationType",
        "sourceRefs",
        "causality"
      ],
      "properties": {
        "relationType": {
          "$ref": "#/$defs/relationType"
        },
        "sourceRefs": {
          "$ref": "#/$defs/sourceRefs"
        },
        "causality": {
          "const": "not_asserted"
        }
      }
    },
    "consentScope": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "patientId",
        "subject",
        "scope",
        "validTo",
        "status",
        "sourceRefs"
      ],
      "properties": {
        "role": {
          "type": "string"
        },
        "caregiverId": {
          "type": "string"
        },
        "caregiverName": {
          "type": "string"
        },
        "areas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "$ref": "#/$defs/consentStatus"
        },
        "sourceRefs": {
          "$ref": "#/$defs/sourceRefs"
        }
      }
    },
    "consentGrant": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "consentGrantId",
        "patientProfileId",
        "grantorUserId",
        "granteeType",
        "purpose",
        "scopes",
        "validFrom",
        "validUntil",
        "status"
      ],
      "properties": {
        "granteeType": {
          "enum": [
            "self",
            "parent",
            "legal_guardian",
            "support_person",
            "doctor",
            "governance"
          ]
        },
        "purpose": {
          "enum": [
            "self_management",
            "care_support",
            "pre_visit_review",
            "admin_governance"
          ]
        },
        "scopes": {
          "type": "array",
          "items": {
            "enum": [
              "profile.view",
              "documents.metadata.view",
              "documents.file.view",
              "documents.upload",
              "medications.view",
              "medications.edit",
              "observations.view",
              "observations.add",
              "questions.view",
              "questions.add",
              "questions.status.mark",
              "timeline.view",
              "report.generate",
              "report.share",
              "report.view",
              "audit.view"
            ]
          }
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "revoked",
            "expired"
          ]
        }
      }
    },
    "auditEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "patientId",
        "date",
        "actor",
        "action",
        "actionType"
      ],
      "properties": {
        "actionType": {
          "$ref": "#/$defs/auditActionType"
        }
      }
    },
    "visitPacket": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaVersion",
        "contractVersion",
        "packetId",
        "version",
        "generatedAt",
        "generatedByUserId",
        "patientProfileId",
        "preparedByRole",
        "status",
        "visitContext",
        "summary90s",
        "topMatters",
        "medicationsToConfirm",
        "questionsForDoctor",
        "timelineHighlights",
        "documentsIncluded",
        "missingOrUncertain",
        "sourceIndex",
        "excludedByScope",
        "safetyNotice",
        "auditPolicy"
      ],
      "properties": {
        "schemaVersion": {
          "const": 7
        },
        "contractVersion": {
          "const": "0.1"
        },
        "packetId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "preparedByRole": {
          "enum": [
            "patient",
            "parent",
            "legal_guardian",
            "support_person"
          ]
        },
        "status": {
          "enum": [
            "draft",
            "ready_to_share",
            "shared",
            "revoked",
            "expired",
            "superseded"
          ]
        },
        "auditPolicy": {
          "type": "object",
          "required": [
            "mode",
            "failClosed"
          ],
          "properties": {
            "mode": {
              "const": "audit-before-read"
            },
            "failClosed": {
              "const": true
            }
          }
        }
      }
    },
    "doctorReadOnlySession": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaVersion",
        "contractVersion",
        "sessionId",
        "packetId",
        "patientProfileId",
        "viewerType",
        "viewerIdentityStatus",
        "consentGrantId",
        "accessScopeId",
        "createdAt",
        "expiresAt",
        "auditStatus",
        "sessionStatus",
        "readOnly",
        "dataVisible",
        "visibleScope",
        "allowedActions",
        "auditTrail"
      ],
      "properties": {
        "schemaVersion": {
          "const": 7
        },
        "contractVersion": {
          "const": "0.1"
        },
        "viewerType": {
          "enum": [
            "guest_doctor",
            "known_clinician",
            "clinic_user_later"
          ]
        },
        "viewerIdentityStatus": {
          "enum": [
            "unknown",
            "declared",
            "verified_later"
          ]
        },
        "auditStatus": {
          "enum": [
            "pending",
            "written",
            "failed_blocked"
          ]
        },
        "sessionStatus": {
          "enum": [
            "created",
            "opened",
            "expired",
            "revoked",
            "blocked"
          ]
        },
        "readOnly": {
          "const": true
        },
        "allowedActions": {
          "type": "array",
          "items": {
            "enum": [
              "open_packet",
              "view_summary",
              "view_source",
              "view_document_metadata",
              "close_session"
            ]
          }
        }
      }
    },
    "sourceQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sources",
        "claims",
        "sourceMissingCount"
      ],
      "properties": {
        "sources": {
          "type": "integer",
          "minimum": 0
        },
        "claims": {
          "type": "integer",
          "minimum": 0
        },
        "sourceMissingCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
